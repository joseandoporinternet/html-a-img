# Puerto del servidor
PORT=3000

# Llave de acceso única para la API (cambia esto por tu propia llave)
API_KEY=tu_llave_secreta_aqui

# Tamaño máximo del HTML (en caracteres)
MAX_HTML_SIZE=500000

# Rate limiting (ventana en ms y máximo de peticiones)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
